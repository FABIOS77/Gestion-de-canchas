<%- include('../../components/header') %>

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-warning text-dark">
                <h4 class="mb-0">Calificar Experiencia</h4>
            </div>
            <div class="card-body">
                
                <%- include('../../components/alert') %>
                
                <h5 class="text-primary"><%= reserva.Horario.Cancha.nombre %></h5>
                <p class="text-muted small">Reserva del <%= reserva.Horario.fecha %></p>

                <form action="/cliente/reservas/resena" method="POST">
                    <input type="hidden" name="reserva_id" value="<%= reserva.id %>">
                    <input type="hidden" name="cancha_id" value="<%= reserva.Horario.cancha_id %>">

                    <div class="mb-3">
                        <label class="form-label fw-bold">Calificación (1 a 5)</label>
                        <select name="calificacion" class="form-select" required>
                            <option value="5">⭐⭐⭐⭐⭐ Excelente</option>
                            <option value="4">⭐⭐⭐⭐ Muy buena</option>
                            <option value="3">⭐⭐⭐ Regular</option>
                            <option value="2">⭐⭐ Mala</option>
                            <option value="1">⭐ Pésima</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Comentario (Anónimo)</label>
                        <textarea name="comentario" class="form-control" rows="4" placeholder="Cuéntanos qué tal estuvo la cancha... La reseña que hagas vas ser publicada de forma anónima." required></textarea>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a href="/cliente/reservas" class="btn btn-secondary">Volver</a>
                        <button type="submit" class="btn btn-success">Publicar Reseña</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('../../components/footer') %>