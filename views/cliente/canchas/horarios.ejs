<%- include('../../components/header') %>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h3 class="text-primary"><%= cancha.nombre %></h3>
                <h5 class="text-muted"><%= cancha.TipoCancha ? cancha.TipoCancha.nombre : 'General' %></h5>
                <p class="mt-3 fs-5"><strong>Precio:</strong> $<%= cancha.precio_por_hora %> / hora</p>
                <a href="/cliente/canchas" class="btn btn-outline-secondary w-100 mt-2">Volver al catálogo</a>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Horarios Disponibles</h5>
            </div>
            <div class="card-body">
                <% if (horarios.length === 0) { %>
                    <div class="alert alert-warning">No hay horarios disponibles próximos para esta cancha.</div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-hover text-center align-middle">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Inicio</th>
                                    <th>Fin</th>
                                    <th>Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% horarios.forEach(horario => { %>
                                    <tr>
                                        <td><strong><%= horario.fecha %></strong></td>
                                        <td><%= horario.hora_inicio %></td>
                                        <td><%= horario.hora_fin %></td>
                                        <td>
                                            <form action="/cliente/reservar" method="POST">
                                                <input type="hidden" name="horario_id" value="<%= horario.id %>">
                                                <button type="submit" class="btn btn-success btn-sm" onclick="return confirm('¿Confirmar reserva para el <%= horario.fecha %> a las <%= horario.hora_inicio %>?');">
                                                    Reservar
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>
<div class="row mt-5">
    <div class="col-12">
        <h4 class="border-bottom pb-2 mb-4">Opiniones de la Cancha</h4>
        
        <% if (resenas && resenas.length > 0) { %>
            <div class="row">
                <% resenas.forEach(resena => { %>
                    <div class="col-md-6 mb-3">
                        <div class="card bg-light border-0 shadow-sm h-100">
                            <div class="card-body">
                                <div class="mb-2 text-warning fs-5">
                                    <!-- Dibujamos las estrellas dinámicamente -->
                                    <% for(let i=0; i<resena.calificacion; i++) { %>★<% } %>
                                    <% for(let i=resena.calificacion; i<5; i++) { %>☆<% } %>
                                </div>
                                <p class="card-text text-muted fst-italic">"<%= resena.comentario %>"</p>
                                <div class="text-end small text-muted mt-2">
                                    - Usuario Anónimo
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="alert alert-secondary text-center">
                Aún no hay reseñas para esta cancha. 
            </div>
        <% } %>
    </div>
</div>

<%- include('../../components/footer') %>