<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Panel de Administración</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <% if (typeof usuario !== 'undefined' && usuario) { %>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="#"> 
            <%= usuario.rol === 'admin' ? 'Panel Admin' : 'Panel Usuario' %></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <% if (usuario.rol === 'admin') { %>
                        <li class="nav-item"><a class="nav-link" href="/admin/canchas">Gestión Canchas</a></li>
                        <li class="nav-item"><a class="nav-link" href="/admin/tipos">Tipos de Cancha</a></li>
                        <li class="nav-item"><a class="nav-link" href="/admin/horarios">Gestión Horarios</a></li>
                        <li class="nav-item"><a class="nav-link" href="/admin/reservas">Ver Reservas</a></li>
                        <li class="nav-item"><a class="nav-link" href="/admin/reservas/resenas">Ver Reseñas</a></li>
                    <% } else if (usuario.rol === 'cliente') { %>
                        <li class="nav-item"><a class="nav-link" href="/cliente/canchas">Canchas Disponibles</a></li>
                        <li class="nav-item"><a class="nav-link" href="/cliente/reservas">Mis Reservas</a></li>
                    <% } %>
                </ul>
                <span class="navbar-text me-3">
                    Usuario: <%= usuario.nombre %>
                </span>
                <a href="/auth/logout" class="btn btn-outline-danger btn-sm" onclick="return confirm('¿Estás seguro de que deseas cerrar sesión?')">Cerrar Sesión</a>
            </div>
        </div>
    </nav>
    <% } %>
    <div class="container mt-4">