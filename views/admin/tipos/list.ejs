<%- include('../../components/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Tipos de Cancha</h2>
    <a href="/admin/tipos/create" class="btn btn-success">Nuevo Tipo</a>
</div>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        <% tipos.forEach(tipo => { %>
        <tr>
            <td><%= tipo.id %></td>
            <td><%= tipo.nombre %></td>
            <td>
                <a href="/admin/tipos/edit/<%= tipo.id %>" class="btn btn-warning btn-sm">Editar</a>
                <form action="/admin/tipos/delete/<%= tipo.id %>" method="POST" class="d-inline" onsubmit="return confirm('¿Eliminar este tipo?');">
                    <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                </form>
            </td>
        </tr>
        <% }) %>
    </tbody>
</table>
<%- include('../../components/footer') %>